# ─────────────────────────────────────────────────────────────────────────────
# DATACLASSES
# ─────────────────────────────────────────────────────────────────────────────

@dataclass(slots=True)
class ArquivoInfo:
    telefone:      str
    nome:          str
    caminho:       str
    extensao:      str
    modificado_em: float


@dataclass(slots=True)
class ResultadoBusca:
    telefone: str
    nome:     str
    caminho:  str
    copiado:  bool = False
    erro:     str  = ""


@dataclass
class EstatisticasIndexacao:
    total_arquivos:   int = 0
    novos:            int = 0
    atualizados:      int = 0
    ignorados_mtime:  int = 0
    dirs_pulados:     int = 0
    dirs_varridos:    int = 0
    pasta_atual:      str = ""
    fase:             str = "Aguardando"
    ultima_indexacao: str = ""


@dataclass
class EstatisticasBusca:
    total_numeros: int = 0
    encontrados:   int = 0
    copiados:      int = 0
    erros:         int = 0
    fase:          str = "Aguardando"


@dataclass
class EstatisticasLimpeza:
    total_verificados: int = 0
    removidos:         int = 0
    fase:              str = "Aguardando"


@dataclass
class ResultadoAvaliacao:
    total_arquivos:    int   = 0
    total_dirs:        int   = 0
    tamanho_bytes:     int   = 0
    tempo_scan_s:      float = 0.0
    por_nivel1:        dict  = field(default_factory=dict)
    cache_path:        str   = ""
    fase:              str   = "Aguardando"
    pasta_atual:       str   = ""


# ─────────────────────────────────────────────────────────────────────────────
# MÓDULO 1 — DATABASE MANAGER
# ─────────────────────────────────────────────────────────────────────────────

class DatabaseManager:

    def __init__(self, db_path: str):
        self.db_path = db_path
        self._local  = threading.local()
        self._batches_desde_checkpoint = 0
        self._inicializar_banco()

    def _conn(self) -> sqlite3.Connection:
        if not hasattr(self._local, "conn") or self._local.conn is None:
            conn = sqlite3.connect(self.db_path, check_same_thread=False)
            conn.execute("PRAGMA journal_mode=WAL;")
            conn.execute("PRAGMA synchronous=NORMAL;")
            conn.execute("PRAGMA temp_store=MEMORY;")
            conn.execute("PRAGMA cache_size=-100000;")
            conn.execute("PRAGMA mmap_size=536870912;")
            conn.row_factory = sqlite3.Row
            self._local.conn = conn
        return self._local.conn

    def _inicializar_banco(self):
        conn = self._conn()
        conn.executescript("""
            CREATE TABLE IF NOT EXISTS arquivos (
                telefone      TEXT NOT NULL,
                nome          TEXT NOT NULL,
                caminho       TEXT PRIMARY KEY,
                extensao      TEXT NOT NULL,
                modificado_em REAL NOT NULL
            );
            CREATE INDEX IF NOT EXISTS idx_telefone ON arquivos(telefone);
            CREATE INDEX IF NOT EXISTS idx_caminho  ON arquivos(caminho);
            CREATE TABLE IF NOT EXISTS metadata (
                chave TEXT PRIMARY KEY,
                valor TEXT
            );
        """)
        conn.commit()

    def salvar_metadata(self, chave: str, valor: str) -> None:
        conn = self._conn()
        conn.execute(
            "INSERT OR REPLACE INTO metadata (chave, valor) VALUES (?, ?)",
            (chave, valor),
        )
        conn.commit()

    def ler_metadata(self, chave: str) -> Optional[str]:
        conn = self._conn()
        row = conn.execute(
            "SELECT valor FROM metadata WHERE chave = ?", (chave,)
        ).fetchone()
        return row["valor"] if row else None

    def obter_timestamp_ultima_indexacao(self) -> Optional[float]:
        valor = self.ler_metadata(META_ULTIMA_INDEXACAO)
        if not valor:
            return None
        try:
            dt = datetime.fromisoformat(valor)
            return dt.timestamp()
        except (ValueError, TypeError):
            return None

    def salvar_checkpoint_indexacao(self, status: str, pasta_atual: str = "") -> None:
        agora_utc = datetime.now(timezone.utc).isoformat()
        conn = self._conn()
        conn.executemany(
            "INSERT OR REPLACE INTO metadata (chave, valor) VALUES (?, ?)",
            [
                (META_ULTIMA_INDEXACAO, agora_utc),
                (META_STATUS_ULTIMA,    status),
                (META_ULTIMA_PASTA,     pasta_atual),
            ],
        )
        conn.commit()
        try:
            conn.execute("PRAGMA wal_checkpoint(PASSIVE);")
            conn.commit()
        except Exception as e:
            log.warning("wal_checkpoint após salvar_checkpoint falhou: %s", e)

    def banco_existe_com_dados(self) -> bool:
        if not os.path.exists(self.db_path):
            return False
        try:
            row = self._conn().execute("SELECT COUNT(*) FROM arquivos").fetchone()
            return row[0] > 0
        except Exception:
            return False

    def arquivo_existe_no_banco(self, caminho: str) -> Optional[float]:
        row = self._conn().execute(
            "SELECT modificado_em FROM arquivos WHERE caminho = ?", (caminho,)
        ).fetchone()
        return row["modificado_em"] if row else None

    def inserir_batch(self, arquivos: list[ArquivoInfo]) -> None:
        if not arquivos:
            return
        conn = self._conn()
        dados = [(a.telefone, a.nome, a.caminho, a.extensao, a.modificado_em) for a in arquivos]
        conn.executemany(
            "INSERT OR REPLACE INTO arquivos (telefone, nome, caminho, extensao, modificado_em) VALUES (?,?,?,?,?)",
            dados,
        )
        conn.commit()
        self._batches_desde_checkpoint += 1
        if self._batches_desde_checkpoint >= 10:
            try:
                conn.execute("PRAGMA wal_checkpoint(TRUNCATE);")
                self._batches_desde_checkpoint = 0
            except Exception as e:
                log.warning("WAL checkpoint falhou: %s", e)

    def buscar_por_telefone(self, telefone: str) -> list[sqlite3.Row]:
        return self._conn().execute(
            "SELECT nome, caminho FROM arquivos WHERE telefone = ?", (telefone,)
        ).fetchall()

    def buscar_batch(self, telefones: list[str]) -> list[sqlite3.Row]:
        """Busca por substring: o campo telefone contém blocos numéricos separados por '|'.
        Um arquivo bate se qualquer bloco contém o número buscado, ou o número contém o bloco."""
        resultados: list[sqlite3.Row] = []
        conn = self._conn()
        vistos: set[str] = set()
        for numero in telefones:
            numero_limpo = re.sub(r'\D', '', numero)
            if not numero_limpo:
                continue
            # Busca arquivos cujo campo telefone contenha o número como substring
            rows = conn.execute(
                "SELECT telefone, nome, caminho FROM arquivos WHERE instr(telefone, ?) > 0",
                (numero_limpo,),
            ).fetchall()
            for row in rows:
                if row["caminho"] not in vistos:
                    vistos.add(row["caminho"])
                    resultados.append(row)
        return resultados

    def remover_inexistentes(self, stats: EstatisticasLimpeza, parar: threading.Event) -> None:
        conn = self._conn()
        stats.fase = "Lendo caminhos do banco..."
        cursor = conn.execute("SELECT caminho FROM arquivos ORDER BY caminho")
        batch_remover: list[str] = []

        while not parar.is_set():
            chunk = cursor.fetchmany(5000)
            if not chunk:
                break
            for row in chunk:
                if parar.is_set():
                    break
                caminho = row[0]
                stats.total_verificados += 1
                if not os.path.exists(caminho):
                    batch_remover.append(caminho)
                    stats.removidos += 1
                if len(batch_remover) >= 1000:
                    conn.executemany("DELETE FROM arquivos WHERE caminho = ?", [(c,) for c in batch_remover])
                    conn.commit()
                    batch_remover.clear()

        if batch_remover:
            conn.executemany("DELETE FROM arquivos WHERE caminho = ?", [(c,) for c in batch_remover])
            conn.commit()

        try:
            conn.execute("PRAGMA wal_checkpoint(TRUNCATE);")
        except Exception:
            pass

        stats.fase = "Concluído" if not parar.is_set() else "Interrompido"

    def contar_total(self) -> int:
        row = self._conn().execute("SELECT COUNT(*) FROM arquivos").fetchone()
        return row[0]

    def fechar(self):
        if hasattr(self._local, "conn") and self._local.conn:
            try:
                self._local.conn.execute("PRAGMA wal_checkpoint(PASSIVE);")
            except Exception:
                pass
            try:
                self._local.conn.close()
            except Exception:
                pass
            self._local.conn = None


# ─────────────────────────────────────────────────────────────────────────────
# MÓDULO 2 — FILE INDEXER
# ─────────────────────────────────────────────────────────────────────────────

class FileIndexer:

    def __init__(self, db_manager: DatabaseManager):
        self.db = db_manager

    @staticmethod
    def extrair_telefone(nome: str) -> str:
        """Extrai todos os blocos numéricos >= 8 dígitos do nome do arquivo,
        concatenados por '|', para que a busca por substring funcione."""
        try:
            stem = os.path.splitext(nome)[0]
            blocos = re.findall(r'\d{8,}', stem)
            return "|".join(blocos) if blocos else ""
        except Exception:
            return ""

    def _obter_mtime_dir(self, caminho: str) -> Optional[float]:
        try:
            return os.stat(caminho).st_mtime
        except OSError:
            return None

    def indexar(
        self,
        raiz: str,
        stats: EstatisticasIndexacao,
        parar: threading.Event,
        pastas_nivel1_filtro: Optional[set] = None,
    ) -> None:
        ts_ultima = self.db.obter_timestamp_ultima_indexacao()
        status_anterior = self.db.ler_metadata(META_STATUS_ULTIMA) or ""
        foi_interrompido = status_anterior == "interrompido"
        modo_incremental = ts_ultima is not None

        dirs_concluidos: set[str] = set()
        if foi_interrompido:
            raw = self.db.ler_metadata(META_DIRS_CONCLUIDOS) or ""
            if raw:
                dirs_concluidos = set(raw.split("\n"))
            ts_dir_skip = None
            stats.fase = f"Retomando — {len(dirs_concluidos)} pastas já indexadas"
        else:
            ts_dir_skip = ts_ultima

        if modo_incremental:
            dt_str = datetime.fromtimestamp(ts_ultima).strftime("%d/%m/%Y %H:%M:%S")
            stats.ultima_indexacao = dt_str
            if not foi_interrompido:
                stats.fase = f"Incremental — última: {dt_str}"
        else:
            stats.fase = "Indexação inicial..."

        stack: list[tuple[str, Optional[float]]] = [(raiz, None)]
        batch: list[ArquivoInfo] = []
        ultima_pasta_visitada = raiz
        nivel1_atual_processando = ""

        try:
            while stack and not parar.is_set():
                dir_atual, dir_mtime_hint = stack.pop()
                stats.pasta_atual     = dir_atual
                ultima_pasta_visitada = dir_atual

                nivel1_do_dir = ""
                if dir_atual != raiz:
                    try:
                        rel = os.path.relpath(dir_atual, raiz)
                        nivel1_do_dir = os.path.join(raiz, rel.split(os.sep)[0])
                    except Exception:
                        nivel1_do_dir = dir_atual

                if (pastas_nivel1_filtro is not None
                        and nivel1_do_dir
                        and nivel1_do_dir not in pastas_nivel1_filtro):
                    stats.dirs_pulados += 1
                    continue

                if foi_interrompido and nivel1_do_dir and nivel1_do_dir in dirs_concluidos:
                    stats.dirs_pulados += 1
                    continue

                if nivel1_do_dir and nivel1_do_dir != nivel1_atual_processando:
                    nivel1_atual_processando = nivel1_do_dir

                if (not foi_interrompido and modo_incremental
                        and ts_dir_skip is not None and dir_atual != raiz):
                    dir_mtime = dir_mtime_hint
                    if dir_mtime is None:
                        dir_mtime = self._obter_mtime_dir(dir_atual)
                    if dir_mtime is not None and dir_mtime <= (ts_dir_skip + MTIME_TOLERANCIA):
                        stats.dirs_pulados += 1
                        continue

                stats.dirs_varridos += 1

                try:
                    with os.scandir(dir_atual) as it:
                        subdirs: list[tuple[str, Optional[float]]] = []
                        for entry in it:
                            if parar.is_set():
                                break
                            try:
                                try:
                                    entry_stat = entry.stat(follow_symlinks=False)
                                except OSError:
                                    continue
                                if entry.is_dir(follow_symlinks=False):
                                    subdirs.append((entry.path, entry_stat.st_mtime))
                                    continue
                                nome = entry.name
                                _, ext = os.path.splitext(nome)
                                if ext.lower() not in EXTENSOES:
                                    continue
                                stats.total_arquivos += 1
                                mtime = entry_stat.st_mtime
                                if modo_incremental and ts_ultima is not None and not foi_interrompido:
                                    if mtime <= (ts_ultima + MTIME_TOLERANCIA):
                                        stats.ignorados_mtime += 1
                                        continue
                                caminho = entry.path
                                mtime_banco = self.db.arquivo_existe_no_banco(caminho)
                                if mtime_banco is not None:
                                    if abs(mtime_banco - mtime) < MTIME_TOLERANCIA:
                                        stats.ignorados_mtime += 1
                                        continue
                                    stats.atualizados += 1
                                    stats.fase = "Processando modificados..."
                                else:
                                    stats.novos += 1
                                    stats.fase = "Processando novos..."
                                telefone = self.extrair_telefone(nome)
                                if not telefone:
                                    continue
                                batch.append(ArquivoInfo(
                                    telefone=telefone, nome=nome, caminho=caminho,
                                    extensao=ext.lower(), modificado_em=mtime,
                                ))
                                if len(batch) >= BATCH_SIZE:
                                    self.db.inserir_batch(batch)
                                    batch.clear()
                                    self.db.salvar_metadata(META_ULTIMA_PASTA, dir_atual)
                            except (PermissionError, OSError):
                                pass
                        stack.extend(subdirs)
                except (PermissionError, OSError) as e:
                    log.warning("Sem acesso: %s — %s", dir_atual, e)

                if foi_interrompido and nivel1_do_dir:
                    restante = any(p.startswith(nivel1_do_dir + os.sep) or p == nivel1_do_dir for p, _ in stack)
                    if not restante and nivel1_do_dir not in dirs_concluidos:
                        dirs_concluidos.add(nivel1_do_dir)
                        self.db.salvar_metadata(META_DIRS_CONCLUIDOS, "\n".join(dirs_concluidos))

        finally:
            if batch:
                try:
                    self.db.inserir_batch(batch)
                    batch.clear()
                except Exception as e:
                    log.warning("Falha no flush final: %s", e)

            if not parar.is_set():
                self.db.salvar_metadata(META_DIRS_CONCLUIDOS, "")
                self.db.salvar_checkpoint_indexacao(status="completo", pasta_atual=ultima_pasta_visitada)
                stats.fase = "Concluído"
            else:
                self.db.salvar_metadata(META_STATUS_ULTIMA, "interrompido")
                self.db.salvar_metadata(META_ULTIMA_PASTA, ultima_pasta_visitada)
                agora_utc = datetime.now(timezone.utc).isoformat()
                self.db.salvar_metadata(META_ULTIMA_INDEXACAO, agora_utc)
                try:
                    conn = self.db._conn()
                    conn.execute("PRAGMA wal_checkpoint(PASSIVE);")
                    conn.commit()
                except Exception as e:
                    log.warning("wal_checkpoint no parar falhou: %s", e)
                stats.fase = "Interrompido"
            self.db.fechar()


# ─────────────────────────────────────────────────────────────────────────────
# MÓDULO 3 — SEARCH ENGINE
# ─────────────────────────────────────────────────────────────────────────────

class SearchEngine:

    def __init__(self, db_manager: DatabaseManager):
        self.db = db_manager

    @staticmethod
    def carregar_numeros_planilha(caminho: str) -> Optional[list[str]]:
        ext = os.path.splitext(caminho)[1].lower()
        numeros: list[str] = []
        try:
            if ext == ".csv":
                df = pd.read_csv(caminho, usecols=[0], dtype=str, header=None)
            else:
                df = pd.read_excel(caminho, usecols=[0], header=None)
            for val in df.iloc[:, 0].dropna():
                try:
                    limpo = str(int(float(str(val).strip())))
                except (ValueError, OverflowError):
                    limpo = str(val).strip()
                if limpo and limpo.lower() not in ("nan", "none", ""):
                    numeros.append(limpo)
            return numeros
        except Exception as e:
            log.exception("Erro ao carregar planilha: %s", caminho)
            messagebox.showerror("Erro na planilha", str(e))
            return None

    def buscar_e_copiar(
        self,
        telefones: list[str],
        destino: str,
        stats: EstatisticasBusca,
        parar: threading.Event,
    ) -> list[ResultadoBusca]:
        stats.total_numeros = len(telefones)
        stats.fase = "Consultando índice..."

        rows = self.db.buscar_batch(telefones)
        stats.encontrados = len(rows)
        stats.fase = f"Copiando {len(rows)} arquivo(s)..."

        resultados: list[ResultadoBusca] = []
        for i, row in enumerate(rows):
            if parar.is_set():
                break
            stats.copiados = i
            nome     = row["nome"]
            origem   = row["caminho"]
            telefone = row["telefone"]
            resultado = ResultadoBusca(telefone=telefone, nome=nome, caminho=origem)
            if not os.path.exists(origem):
                resultado.erro = "Arquivo não encontrado (índice desatualizado)"
                stats.erros += 1
                resultados.append(resultado)
                continue
            destino_arquivo = os.path.join(destino, nome)
            try:
                if not os.path.exists(destino_arquivo):
                    shutil.copy2(origem, destino_arquivo)
                resultado.copiado = True
            except Exception as e:
                resultado.erro = str(e)
                stats.erros += 1
                log.warning("Falha ao copiar %s: %s", nome, e)
            resultados.append(resultado)

        stats.copiados = sum(1 for r in resultados if r.copiado)
        stats.fase = "Concluído"
        return resultados


# ─────────────────────────────────────────────────────────────────────────────
# MÓDULO 4 — DIRECTORY EVALUATOR
# ─────────────────────────────────────────────────────────────────────────────

class DirectoryEvaluator:

    def __init__(self, db_path: str):
        base = os.path.splitext(db_path)[0]
        self.cache_path = base + AVALIACAO_CACHE_SUFIXO

    def avaliar(self, raiz: str, resultado: ResultadoAvaliacao, parar: threading.Event) -> None:
        ts_inicio = time.monotonic()
        resultado.fase = "Varrendo diretório..."
        resultado.cache_path = self.cache_path
        stack: list[str] = [raiz]
        por_nivel1: dict[str, dict] = {}

        try:
            while stack and not parar.is_set():
                dir_atual = stack.pop()
                resultado.pasta_atual = dir_atual
                resultado.total_dirs += 1
                nivel1 = ""
                if dir_atual != raiz:
                    try:
                        rel = os.path.relpath(dir_atual, raiz)
                        nivel1 = os.path.join(raiz, rel.split(os.sep)[0])
                    except Exception:
                        nivel1 = dir_atual
                if nivel1 and nivel1 not in por_nivel1:
                    por_nivel1[nivel1] = {"arquivos": 0, "bytes": 0}
                try:
                    with os.scandir(dir_atual) as it:
                        for entry in it:
                            if parar.is_set():
                                break
                            try:
                                st = entry.stat(follow_symlinks=False)
                            except OSError:
                                continue
                            if entry.is_dir(follow_symlinks=False):
                                stack.append(entry.path)
                                continue
                            _, ext = os.path.splitext(entry.name)
                            if ext.lower() not in EXTENSOES:
                                continue
                            resultado.total_arquivos += 1
                            resultado.tamanho_bytes  += st.st_size
                            if nivel1:
                                por_nivel1[nivel1]["arquivos"] += 1
                                por_nivel1[nivel1]["bytes"]    += st.st_size
                except (PermissionError, OSError) as e:
                    log.warning("Avaliação sem acesso: %s — %s", dir_atual, e)
        finally:
            resultado.tempo_scan_s = time.monotonic() - ts_inicio
            resultado.por_nivel1   = por_nivel1
            resultado.fase = "Interrompido" if parar.is_set() else "Concluído"
            self._salvar_cache(resultado)

    def _salvar_cache(self, resultado: ResultadoAvaliacao) -> None:
        try:
            dados = {
                "gerado_em":      datetime.now().isoformat(),
                "total_arquivos": resultado.total_arquivos,
                "total_dirs":     resultado.total_dirs,
                "tamanho_bytes":  resultado.tamanho_bytes,
                "tempo_scan_s":   resultado.tempo_scan_s,
                "por_nivel1":     resultado.por_nivel1,
                "fase":           resultado.fase,
            }
            with open(self.cache_path, "w", encoding="utf-8") as f:
                json.dump(dados, f, ensure_ascii=False, indent=2)
        except Exception as e:
            log.warning("Falha ao salvar cache: %s", e)

    def carregar_cache(self) -> Optional[dict]:
        if not os.path.exists(self.cache_path):
            return None
        try:
            with open(self.cache_path, "r", encoding="utf-8") as f:
                return json.load(f)
        except Exception:
            return None

    @staticmethod
    def formatar_tamanho(b: int) -> str:
        for unit in ("B", "KB", "MB", "GB", "TB"):
            if b < 1024:
                return f"{b:.1f} {unit}"
            b /= 1024
        return f"{b:.1f} PB"

    @staticmethod
    def estimar_tempo(total_arquivos: int) -> str:
        segundos = total_arquivos / VELOCIDADE_ESTIMADA_ARQ_S
        if segundos < 60:
            return f"~{int(segundos)}s"
        elif segundos < 3600:
            return f"~{int(segundos/60)}min"
        else:
            h = int(segundos // 3600)
            m = int((segundos % 3600) // 60)
            return f"~{h}h {m}min"


# ─────────────────────────────────────────────────────────────────────────────
# MÓDULO 5 — TARGETED SCANNER
# ─────────────────────────────────────────────────────────────────────────────

class TargetedScanner:

    _RE_SEGMENTOS = re.compile(r'^GRV_\d+_(\d+)_S__(.+?)(?:_\d+#|#)', re.IGNORECASE)

    def __init__(self, db_manager: DatabaseManager):
        self.db = db_manager

    @staticmethod
    def normalizar_numero(n: str) -> str:
        return re.sub(r'\D', '', str(n))

    @classmethod
    def extrair_candidatos(cls, nome_arquivo: str) -> list[str]:
        """Retorna todos os blocos numéricos >= 8 dígitos encontrados no nome.
        A correspondência com os números-alvo é feita por substring (ver varrer_e_salvar)."""
        stem = os.path.splitext(nome_arquivo)[0]
        blocos: set[str] = set()
        for bloco in re.findall(r'\d{8,}', stem):
            blocos.add(bloco)
            # Remove prefixos internacionais comuns para ampliar o match
            for prefixo in ('55', '0055', '0'):
                if bloco.startswith(prefixo) and len(bloco) > len(prefixo) + 7:
                    blocos.add(bloco[len(prefixo):])
        return [b for b in blocos if b]

    def varrer_e_salvar(
        self,
        raiz: str,
        numeros_alvo: set[str],
        stats: EstatisticasIndexacao,
        parar: threading.Event,
        callback_resultado: Optional[Callable] = None,
    ) -> None:
        batch: list[ArquivoInfo] = []
        stack: list[str] = [raiz]
        stats.fase = "Varrendo..."

        try:
            while stack and not parar.is_set():
                dir_atual = stack.pop()
                stats.pasta_atual = dir_atual
                stats.dirs_varridos += 1
                try:
                    with os.scandir(dir_atual) as it:
                        for entry in it:
                            if parar.is_set():
                                break
                            try:
                                st = entry.stat(follow_symlinks=False)
                            except OSError:
                                continue
                            if entry.is_dir(follow_symlinks=False):
                                stack.append(entry.path)
                                continue
                            nome = entry.name
                            _, ext = os.path.splitext(nome)
                            if ext.lower() not in EXTENSOES:
                                continue
                            stats.total_arquivos += 1
                            candidatos = self.extrair_candidatos(nome)
                            numero_encontrado = None
                            for alvo in numeros_alvo:
                                for c in candidatos:
                                    # Match se o alvo está dentro do bloco ou o bloco dentro do alvo
                                    if alvo in c or c in alvo:
                                        numero_encontrado = alvo
                                        break
                                if numero_encontrado:
                                    break
                            if numero_encontrado is None:
                                stats.ignorados_mtime += 1
                                continue
                            stats.novos += 1
                            info = ArquivoInfo(
                                telefone=numero_encontrado, nome=nome, caminho=entry.path,
                                extensao=ext.lower(), modificado_em=st.st_mtime,
                            )
                            batch.append(info)
                            if callback_resultado:
                                callback_resultado(info)
                            if len(batch) >= BATCH_SIZE:
                                self.db.inserir_batch(batch)
                                batch.clear()
                except (PermissionError, OSError) as e:
                    log.warning("TargetedScanner sem acesso: %s — %s", dir_atual, e)
        finally:
            if batch:
                try:
                    self.db.inserir_batch(batch)
                except Exception as e:
                    log.warning("Flush final TargetedScanner falhou: %s", e)
            if not parar.is_set():
                self.db.salvar_checkpoint_indexacao(status="completo_targeted")
                stats.fase = "Concluído"
            else:
                stats.fase = "Interrompido"
            self.db.fechar()


