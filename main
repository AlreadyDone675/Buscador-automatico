    # ─────────────────────────────────────────────────────────────────────────
    # SELETORES DE ARQUIVO/PASTA
    # ─────────────────────────────────────────────────────────────────────────

    def _escolher_db(self):
        p = filedialog.asksaveasfilename(
            defaultextension=".db", filetypes=[("SQLite Database", "*.db")],
            title="Escolher / criar banco de índice")
        if p:
            self.ent_db.delete(0, tk.END)
            self.ent_db.insert(0, p)
            self._verificar_banco()

    def _escolher_raiz(self):
        d = filedialog.askdirectory(title="Selecionar pasta raiz dos áudios")
        if d:
            self.ent_raiz.delete(0, tk.END)
            self.ent_raiz.insert(0, d)

    def _escolher_planilha(self):
        p = filedialog.askopenfilename(
            filetypes=[("Planilhas", "*.xlsx *.xls *.csv"), ("Todos", "*.*")],
            title="Selecionar planilha de números")
        if p:
            self.ent_planilha.delete(0, tk.END)
            self.ent_planilha.insert(0, p)
            self._atualizar_label_planilha(p)

    def _escolher_destino(self):
        d = filedialog.askdirectory(title="Selecionar pasta de destino")
        if d:
            self.ent_destino.delete(0, tk.END)
            self.ent_destino.insert(0, d)

    def _escolher_planilha_alvo(self):
        p = filedialog.askopenfilename(
            filetypes=[("Planilhas", "*.xlsx *.xls *.csv"), ("Todos", "*.*")],
            title="Selecionar planilha de números-alvo")
        if p:
            self.ent_alvo.delete(0, tk.END)
            self.ent_alvo.insert(0, p)
            self._atualizar_label_alvo(p)

    def _escolher_dir(self, entry: ttk.Entry):
        d = filedialog.askdirectory(title="Selecionar pasta")
        if d:
            entry.delete(0, tk.END)
            entry.insert(0, d)

    # ─────────────────────────────────────────────────────────────────────────
    # HELPERS DE PLANILHA
    # ─────────────────────────────────────────────────────────────────────────

    def _atualizar_label_planilha(self, caminho: str):
        try:
            numeros = SearchEngine.carregar_numeros_planilha(caminho)
            if numeros:
                self.lbl_numeros_carregados.config(
                    text=f"✔  {len(numeros):,} números carregados — ex: {', '.join(numeros[:3])}{'...' if len(numeros)>3 else ''}",
                    foreground="green")
            else:
                self.lbl_numeros_carregados.config(text="⚠  Nenhum número encontrado.", foreground="orange")
        except Exception as e:
            self.lbl_numeros_carregados.config(text=f"✘  Erro: {e}", foreground="red")

    def _atualizar_label_alvo(self, caminho: str):
        try:
            numeros = self._ler_planilha_alvo_raw(caminho)
            if numeros:
                self.lbl_alvo_status.config(
                    text=f"✔  {len(numeros):,} números carregados da planilha — ex: {', '.join(numeros[:3])}{'...' if len(numeros)>3 else ''}",
                    foreground="green")
            else:
                self.lbl_alvo_status.config(text="⚠  Nenhum número encontrado na planilha.", foreground="orange")
        except Exception as e:
            self.lbl_alvo_status.config(text=f"✘  Erro: {e}", foreground="red")

    @staticmethod
    def _ler_planilha_alvo_raw(caminho: str) -> list[str]:
        ext = os.path.splitext(caminho)[1].lower()
        if ext == ".csv":
            df = pd.read_csv(caminho, usecols=[0], dtype=str, header=None)
        else:
            df = pd.read_excel(caminho, usecols=[0], dtype=str, header=None)
        numeros = []
        for val in df.iloc[:, 0].dropna():
            limpo = str(val).strip().rstrip(".0")
            if limpo:
                numeros.append(limpo)
        return numeros

    def _preview_planilha(self):
        caminho = self.ent_planilha.get().strip()
        if not caminho or not os.path.exists(caminho):
            messagebox.showerror("Erro", "Selecione uma planilha válida primeiro.")
            return
        numeros = SearchEngine.carregar_numeros_planilha(caminho)
        if numeros is None:
            return
        self._mostrar_preview_numeros(numeros, "Números da planilha de busca")

    def _preview_alvo(self):
        numeros_alvo = self._carregar_numeros_alvo(silencioso=True)
        if numeros_alvo is None:
            messagebox.showwarning("Aviso", "Informe os números pela planilha ou pela caixa de texto.")
            return
        self._mostrar_preview_numeros(sorted(numeros_alvo), "Números para varredura direcionada")

    def _mostrar_preview_numeros(self, numeros: list[str], titulo: str):
        win = tk.Toplevel(self.root)
        win.title(titulo)
        win.geometry("420x500")
        win.resizable(True, True)
        pad = ttk.Frame(win, padding=10)
        pad.pack(fill="both", expand=True)
        pad.rowconfigure(1, weight=1)
        pad.columnconfigure(0, weight=1)

        ttk.Label(pad, text=f"Total: {len(numeros):,} números", font=("Segoe UI", 9, "bold")).grid(row=0, sticky="w", pady=(0,6))

        lb = tk.Listbox(pad, font=("Consolas", 9))
        sb = ttk.Scrollbar(pad, orient="vertical", command=lb.yview)
        lb.configure(yscrollcommand=sb.set)
        lb.grid(row=1, column=0, sticky="nsew")
        sb.grid(row=1, column=1, sticky="ns")

        for n in numeros[:5000]:
            lb.insert(tk.END, n)
        if len(numeros) > 5000:
            lb.insert(tk.END, f"... (+{len(numeros)-5000:,} mais)")

        ttk.Button(pad, text="Fechar", command=win.destroy).grid(row=2, sticky="e", pady=(6,0))

    # ─────────────────────────────────────────────────────────────────────────
    # BANCO
    # ─────────────────────────────────────────────────────────────────────────

    def _verificar_banco(self):
        db_path = self.ent_db.get().strip()
        if not db_path:
            return
        try:
            db    = DatabaseManager(db_path)
            total = db.contar_total()
            ts_checkpoint = db.obter_timestamp_ultima_indexacao()
            status_ultimo = db.ler_metadata(META_STATUS_ULTIMA) or "—"
            db.fechar()

            if total > 0:
                self.lbl_status_db.config(
                    text=f"✔  Banco encontrado — {total:,} arquivos indexados",
                    foreground="green")
                self.lbl_total_idx.config(text=f"Total indexado: {total:,}")
                if ts_checkpoint:
                    dt_str = datetime.fromtimestamp(ts_checkpoint).strftime("%d/%m/%Y às %H:%M:%S")
                    cor   = "green"  if status_ultimo == "completo" else "orange"
                    icone = "✔"     if status_ultimo == "completo" else "⚠"
                    self.lbl_checkpoint.config(
                        text=f"{icone}  Última indexação: {dt_str} ({status_ultimo})",
                        foreground=cor)
                else:
                    self.lbl_checkpoint.config(
                        text="⚠  Sem checkpoint — próxima indexação será completa",
                        foreground="orange")
            else:
                self.lbl_status_db.config(
                    text="⚠  Banco vazio — execute 'Atualizar Índice' primeiro",
                    foreground="orange")
                self.lbl_checkpoint.config(text="", foreground="gray")
        except Exception as e:
            self.lbl_status_db.config(text=f"✘  Erro ao verificar banco: {e}", foreground="red")
            self.lbl_checkpoint.config(text="", foreground="gray")

    def _get_db(self) -> Optional[DatabaseManager]:
        db_path = self.ent_db.get().strip()
        if not db_path:
            messagebox.showerror("Erro", "Informe o caminho do banco de dados.")
            return None
        try:
            return DatabaseManager(db_path)
        except Exception as e:
            messagebox.showerror("Erro no banco", str(e))
            return None

    # ─────────────────────────────────────────────────────────────────────────
    # INDEXAÇÃO
    # ─────────────────────────────────────────────────────────────────────────

    def _iniciar_indexacao(self, pastas_nivel1_filtro: Optional[set] = None):
        raiz = self.ent_raiz.get().strip()
        if not os.path.isdir(raiz):
            messagebox.showerror("Erro", "Pasta raiz inválida ou inexistente.")
            return
        db = self._get_db()
        if db is None:
            return
        self.db      = db
        self.indexer = FileIndexer(db)
        self._pastas_nivel1_filtro = pastas_nivel1_filtro
        self._parar.clear()
        self._stats_idx  = EstatisticasIndexacao()
        self._ts_inicio  = time.monotonic()
        self._modo_ativo = "indexando"
        self.lista.delete(0, tk.END)
        self._set_ui_ativa(modo="indexando")
        threading.Thread(target=self._worker_indexacao, args=(raiz,), daemon=True, name="Indexador").start()
        self._agendar_ui()

    def _worker_indexacao(self, raiz: str):
        filtro = getattr(self, "_pastas_nivel1_filtro", None)
        try:
            self.indexer.indexar(raiz, self._stats_idx, self._parar, pastas_nivel1_filtro=filtro)
        except Exception as e:
            log.exception("Erro crítico na indexação: %s", e)
            self._stats_idx.fase = f"ERRO: {e}"
            try:
                if self.db:
                    self.db.fechar()
            except Exception:
                pass
        finally:
            self.root.after(0, self._finalizar_indexacao)

    def _finalizar_indexacao(self):
        self._cancelar_timer_ui()
        self._set_ui_inativa()
        s       = self._stats_idx
        elapsed = max(time.monotonic() - self._ts_inicio, 0.01)
        vel     = int(s.total_arquivos / elapsed)
        total_banco = self.db.contar_total() if self.db else 0
        total_dirs  = s.dirs_varridos + s.dirs_pulados
        pct_pulados = (s.dirs_pulados / total_dirs * 100) if total_dirs > 0 else 0
        pct_ignorados = (s.ignorados_mtime / s.total_arquivos * 100) if s.total_arquivos > 0 else 0

        self.lbl_fase.config(text="Indexação concluída.", foreground="green")
        self.lbl_total_idx.config(text=f"Total indexado: {total_banco:,}")
        self._verificar_banco()

        linhas = [
            "INDEXAÇÃO CONCLUÍDA",
            f"  Modo              : {'Incremental' if s.ultima_indexacao else 'Completo (inicial)'}",
            f"  Dirs varridos     : {s.dirs_varridos:,}",
            f"  Dirs pulados      : {s.dirs_pulados:,}  ({pct_pulados:.1f}%)",
            f"  Arq. encontrados  : {s.total_arquivos:,}",
            f"  Arq. ignorados    : {s.ignorados_mtime:,}  ({pct_ignorados:.1f}%)",
            f"  Novos             : {s.novos:,}",
            f"  Atualizados       : {s.atualizados:,}",
            f"  Total banco       : {total_banco:,}",
            f"  Tempo total       : {elapsed:.1f}s",
            f"  Velocidade        : {vel:,} arq/s",
        ]
        self.lista.delete(0, tk.END)
        self.lista.insert(tk.END, *linhas)

        messagebox.showinfo("Indexação concluída",
            f"Novos: {s.novos:,}   Atualizados: {s.atualizados:,}\n"
            f"Dirs pulados: {s.dirs_pulados:,} ({pct_pulados:.1f}%)\n"
            f"Total banco: {total_banco:,}\n"
            f"Tempo: {elapsed:.1f}s  |  Vel: {vel:,} arq/s")

    # ─────────────────────────────────────────────────────────────────────────
    # LIMPEZA
    # ─────────────────────────────────────────────────────────────────────────

    def _iniciar_limpeza(self):
        db = self._get_db()
        if db is None:
            return
        if not db.banco_existe_com_dados():
            messagebox.showinfo("Aviso", "O banco está vazio.")
            db.fechar()
            return
        total = db.contar_total()
        if not messagebox.askyesno("Limpar Órfãos",
            f"Verificará {total:,} caminhos no disco para remover arquivos deletados.\n\nContinuar?"):
            db.fechar()
            return
        self.db = db
        self._parar.clear()
        self._stats_limp = EstatisticasLimpeza()
        self._ts_inicio  = time.monotonic()
        self._modo_ativo = "limpando"
        self.lista.delete(0, tk.END)
        self._set_ui_ativa(modo="limpando")
        threading.Thread(target=self._worker_limpeza, daemon=True, name="Limpeza").start()
        self._agendar_ui()

    def _worker_limpeza(self):
        try:
            self.db.remover_inexistentes(self._stats_limp, self._parar)
        except Exception as e:
            log.exception("Erro na limpeza: %s", e)
            self._stats_limp.fase = f"ERRO: {e}"
        finally:
            self.root.after(0, self._finalizar_limpeza)

    def _finalizar_limpeza(self):
        self._cancelar_timer_ui()
        self._set_ui_inativa()
        s       = self._stats_limp
        elapsed = max(time.monotonic() - self._ts_inicio, 0.01)
        total_banco = self.db.contar_total() if self.db else 0
        self.lbl_fase.config(text="Limpeza concluída.", foreground="green")
        self.lbl_total_idx.config(text=f"Total indexado: {total_banco:,}")
        linhas = ["LIMPEZA DE ÓRFÃOS CONCLUÍDA",
                  f"  Verificados : {s.total_verificados:,}",
                  f"  Removidos   : {s.removidos:,}",
                  f"  Restantes   : {total_banco:,}",
                  f"  Tempo       : {elapsed:.1f}s"]
        self.lista.delete(0, tk.END)
        self.lista.insert(tk.END, *linhas)
        messagebox.showinfo("Limpeza concluída",
            f"Verificados: {s.total_verificados:,}\nRemovidos: {s.removidos:,}\n"
            f"Restantes: {total_banco:,}\nTempo: {elapsed:.1f}s")
        self._verificar_banco()

    # ─────────────────────────────────────────────────────────────────────────
    # BUSCA
    # ─────────────────────────────────────────────────────────────────────────

    def _iniciar_busca(self):
        planilha = self.ent_planilha.get().strip()
        if not planilha or not os.path.exists(planilha):
            messagebox.showerror("Erro",
                "Selecione uma planilha válida.\n\n"
                "Clique em '…' ao lado do campo 'Planilha' para escolher o arquivo.")
            return

        destino = self.ent_destino.get().strip()
        if not destino:
            messagebox.showerror("Erro", "Informe a pasta de destino.")
            return

        db = self._get_db()
        if db is None:
            return
        if not db.banco_existe_com_dados():
            messagebox.showwarning("Índice vazio",
                "O banco ainda não possui dados.\nExecute 'Atualizar Índice' primeiro.")
            db.fechar()
            return

        engine  = SearchEngine(db)
        numeros = engine.carregar_numeros_planilha(planilha)
        if numeros is None:
            db.fechar()
            return
        if not numeros:
            messagebox.showerror("Erro", "Nenhum número encontrado na planilha.")
            db.fechar()
            return

        os.makedirs(destino, exist_ok=True)
        self.db     = db
        self.engine = engine
        self._parar.clear()
        self._stats_bus  = EstatisticasBusca()
        self._ts_inicio  = time.monotonic()
        self._modo_ativo = "buscando"
        self.lista.delete(0, tk.END)
        self.lista.insert(tk.END, f"Buscando {len(numeros):,} números no índice...")
        self._set_ui_ativa(modo="buscando")
        threading.Thread(target=self._worker_busca, args=(numeros, destino),
                         daemon=True, name="Busca").start()
        self._agendar_ui()

    def _worker_busca(self, numeros: list[str], destino: str):
        resultados: list[ResultadoBusca] = []
        try:
            resultados = self.engine.buscar_e_copiar(numeros, destino, self._stats_bus, self._parar)
        except Exception as e:
            log.exception("Erro crítico na busca: %s", e)
            self._stats_bus.fase = f"ERRO: {e}"
        finally:
            self.root.after(0, lambda: self._finalizar_busca(resultados, destino))

    def _finalizar_busca(self, resultados: list[ResultadoBusca], destino: str):
        self._cancelar_timer_ui()
        self._set_ui_inativa()
        s       = self._stats_bus
        elapsed = max(time.monotonic() - self._ts_inicio, 0.01)
        self.lbl_fase.config(text=f"Busca concluída em {elapsed:.2f}s.", foreground="green")

        linhas = [
            f"{'─'*70}",
            f"  BUSCA CONCLUÍDA — {elapsed:.3f}s",
            f"  Números buscados  : {s.total_numeros:,}",
            f"  Arquivos no índice: {s.encontrados:,}",
            f"  Copiados          : {s.copiados:,}",
            f"  Erros             : {s.erros:,}",
            f"{'─'*70}",
        ]
        for r in resultados:
            if r.copiado and len(linhas) < MAX_LINHAS_UI:
                linhas.append(f"  ✔  [{r.telefone}]  {r.nome}")
        for r in resultados:
            if r.erro and len(linhas) < MAX_LINHAS_UI + 200:
                linhas.append(f"  ✘  {r.nome} — {r.erro}")

        self.lista.delete(0, tk.END)
        if linhas:
            self.lista.insert(tk.END, *linhas)
            self.lista.yview_moveto(0.0)

        self.lbl_contadores.config(
            text=(f"Buscados: {s.total_numeros:,}   Encontrados: {s.encontrados:,}   "
                  f"Copiados: {s.copiados:,}   Erros: {s.erros:,}   Tempo: {elapsed:.3f}s"))

        msg = (f"Busca concluída!\n\n"
               f"Números buscados  : {s.total_numeros:,}\n"
               f"Arquivos no índice: {s.encontrados:,}\n"
               f"Copiados          : {s.copiados:,}\n"
               f"Erros             : {s.erros:,}\n"
               f"Tempo total       : {elapsed:.3f}s")
        if s.erros:
            msg += f"\n\n⚠ {s.erros} erro(s) — veja a lista."
        messagebox.showinfo("Busca concluída", msg)

        if s.copiados > 0 and os.path.isdir(destino):
            try:
                subprocess.Popen(["explorer", os.path.normpath(destino)])
            except Exception:
                pass

    # ─────────────────────────────────────────────────────────────────────────
    # AVALIAÇÃO DE DIRETÓRIO
    # ─────────────────────────────────────────────────────────────────────────

    def _abrir_janela_avaliacao(self):
        raiz = self.ent_raiz.get().strip()
        if not os.path.isdir(raiz):
            messagebox.showerror("Erro", "Pasta raiz inválida ou inexistente.")
            return
        db_path = self.ent_db.get().strip()
        if not db_path:
            messagebox.showerror("Erro", "Informe o caminho do banco de dados.")
            return

        avaliador = DirectoryEvaluator(db_path)
        cache = avaliador.carregar_cache()
        if cache:
            dt_cache = cache.get("gerado_em", "")[:19].replace("T", " às ")
            if messagebox.askyesno("Cache encontrado",
                f"Existe avaliação salva de {dt_cache}.\nUsar esse resultado?"):
                self._mostrar_resultado_avaliacao(cache, avaliador, raiz, db_path, de_cache=True)
                return

        win = tk.Toplevel(self.root)
        win.title("Avaliando...")
        win.geometry("520x160")
        win.resizable(False, False)
        win.grab_set()

        pad = ttk.Frame(win, padding=18)
        pad.pack(fill="both", expand=True)
        ttk.Label(pad, text="Varrendo diretório para avaliação...", font=("Segoe UI", 10, "bold")).pack(anchor="w")
        pb = ttk.Progressbar(pad, orient="horizontal", mode="indeterminate", length=480)
        pb.pack(fill="x", pady=8)
        pb.start(12)
        lbl_info  = ttk.Label(pad, text="Iniciando...", font=("Consolas", 8), foreground="#555")
        lbl_info.pack(anchor="w")
        lbl_pasta = ttk.Label(pad, text="", font=("Consolas", 7), foreground="gray", anchor="w", width=70)
        lbl_pasta.pack(anchor="w")
        parar_ev  = threading.Event()
        ttk.Button(pad, text="Cancelar", command=lambda: parar_ev.set()).pack(anchor="e", pady=(6,0))

        resultado = ResultadoAvaliacao()
        ts_ini    = time.monotonic()

        def _tick():
            if resultado.fase in ("Concluído", "Interrompido"):
                win.destroy()
                if resultado.fase == "Concluído":
                    self._mostrar_resultado_avaliacao(avaliador.carregar_cache(), avaliador, raiz, db_path, de_cache=False)
                return
            elapsed = time.monotonic() - ts_ini
            lbl_info.config(text=(f"Dirs: {resultado.total_dirs:,}   Arquivos: {resultado.total_arquivos:,}   "
                                  f"Tamanho: {DirectoryEvaluator.formatar_tamanho(resultado.tamanho_bytes)}   "
                                  f"Tempo: {elapsed:.0f}s"))
            pasta = resultado.pasta_atual
            if pasta:
                lbl_pasta.config(text=("…" + pasta[-65:]) if len(pasta) > 68 else pasta)
            win.after(600, _tick)

        threading.Thread(target=avaliador.avaliar, args=(raiz, resultado, parar_ev), daemon=True).start()
        win.after(600, _tick)

    def _mostrar_resultado_avaliacao(self, cache, avaliador, raiz, db_path, de_cache):
        if not cache:
            messagebox.showerror("Erro", "Não foi possível carregar resultado.")
            return
        total_arq   = cache.get("total_arquivos", 0)
        total_bytes = cache.get("tamanho_bytes", 0)
        tempo_scan  = cache.get("tempo_scan_s", 0)
        por_nivel1  = cache.get("por_nivel1", {})
        fase        = cache.get("fase", "")
        dt_cache    = cache.get("gerado_em", "")[:19].replace("T", " às ")
        fmt = DirectoryEvaluator.formatar_tamanho

        win = tk.Toplevel(self.root)
        win.title("Resultado da Avaliação")
        win.geometry("900x620")
        win.resizable(True, True)
        pad = ttk.Frame(win, padding=14)
        pad.pack(fill="both", expand=True)
        pad.columnconfigure(0, weight=1)
        pad.rowconfigure(3, weight=1)

        origem_txt = "📁 cache" if de_cache else "🔍 varredura nova"
        ttk.Label(pad, text=f"Avaliação — {origem_txt} — {dt_cache}",
                  font=("Segoe UI", 9, "italic"), foreground="gray").grid(row=0, sticky="w", pady=(0,4))

        resumo = (f"Total de arquivos  : {total_arq:,}\n"
                  f"Tamanho total      : {fmt(total_bytes)}\n"
                  f"Tempo de varredura : {tempo_scan:.1f}s\n"
                  f"Tempo est. indexar : {DirectoryEvaluator.estimar_tempo(total_arq)}\n"
                  f"Pastas nível 1     : {len(por_nivel1):,}")
        if fase == "Interrompido":
            resumo += "\n⚠  Varredura interrompida — resultado parcial"
        ttk.Label(pad, text=resumo, font=("Consolas", 9), justify="left",
                  relief="groove", padding=10).grid(row=1, sticky="ew", pady=(0,8))

        ttk.Label(pad, text="Detalhamento por pasta nível 1 (selecione as que deseja indexar):",
                  font=("Segoe UI", 9)).grid(row=2, sticky="w", pady=(0,4))

        tf = ttk.Frame(pad)
        tf.grid(row=3, sticky="nsew", pady=(0,8))
        tf.columnconfigure(0, weight=1)
        tf.rowconfigure(0, weight=1)

        cols = ("pasta", "arquivos", "tamanho", "tempo_est", "pct")
        tree = ttk.Treeview(tf, columns=cols, show="headings", selectmode="extended", height=14)
        for col, txt, w, anc in [
            ("pasta","Pasta nível 1",380,"w"),("arquivos","Arquivos",90,"e"),
            ("tamanho","Tamanho",100,"e"),("tempo_est","Tempo est.",100,"center"),("pct","% total",80,"center")]:
            tree.heading(col, text=txt)
            tree.column(col, width=w, anchor=anc)
        sb = ttk.Scrollbar(tf, orient="vertical", command=tree.yview)
        tree.configure(yscrollcommand=sb.set)
        tree.grid(row=0, column=0, sticky="nsew")
        sb.grid(row=0, column=1, sticky="ns")

        for caminho, info in sorted(por_nivel1.items(), key=lambda x: x[1]["arquivos"], reverse=True):
            arq = info["arquivos"]
            pct = (arq / total_arq * 100) if total_arq > 0 else 0
            tree.insert("", "end", iid=caminho, values=(
                os.path.basename(caminho) or caminho,
                f"{arq:,}", fmt(info["bytes"]),
                DirectoryEvaluator.estimar_tempo(arq), f"{pct:.1f}%"))
        tree.selection_set(tree.get_children())

        rod = ttk.Frame(pad)
        rod.grid(row=4, sticky="ew")
        rod.columnconfigure(0, weight=1)
        lbl_sel = ttk.Label(rod, text="", font=("Consolas", 9))
        lbl_sel.grid(row=0, sticky="w")

        def _upd(e=None):
            sel = tree.selection()
            a = sum(por_nivel1[s]["arquivos"] for s in sel if s in por_nivel1)
            b = sum(por_nivel1[s]["bytes"]    for s in sel if s in por_nivel1)
            lbl_sel.config(text=(f"Selecionados: {len(sel):,} pastas   Arquivos: {a:,}   "
                                 f"Tamanho: {fmt(b)}   Tempo est.: {DirectoryEvaluator.estimar_tempo(a)}"))
        tree.bind("<<TreeviewSelect>>", _upd)
        _upd()

        bf = ttk.Frame(rod)
        bf.grid(row=1, sticky="e", pady=(8,0))
        ttk.Button(bf, text="Selecionar tudo",
                   command=lambda: (tree.selection_set(tree.get_children()), _upd())).pack(side="left", padx=4)
        ttk.Button(bf, text="Desmarcar tudo",
                   command=lambda: (tree.selection_remove(tree.get_children()), _upd())).pack(side="left", padx=4)

        def _iniciar():
            sel = list(tree.selection())
            if not sel:
                messagebox.showwarning("Aviso", "Nenhuma pasta selecionada.")
                return
            win.destroy()
            self._iniciar_indexacao(pastas_nivel1_filtro=set(sel))

        ttk.Button(bf, text="▶  Indexar selecionadas", style="Accent.TButton",
                   command=_iniciar).pack(side="left", padx=(12,0))
        ttk.Button(bf, text="Fechar", command=win.destroy).pack(side="left", padx=4)

    # ─────────────────────────────────────────────────────────────────────────
    # VARREDURA DIRECIONADA
    # ─────────────────────────────────────────────────────────────────────────

    def _carregar_numeros_alvo(self, silencioso: bool = False) -> Optional[set[str]]:
        numeros: list[str] = []

        planilha = self.ent_alvo.get().strip()
        if planilha and os.path.exists(planilha):
            try:
                numeros.extend(self._ler_planilha_alvo_raw(planilha))
            except Exception as e:
                messagebox.showerror("Erro na planilha", f"Não foi possível ler:\n{e}")
                return None

        texto_direto = self.txt_numeros_diretos.get("1.0", "end").strip()
        if texto_direto:
            for linha in texto_direto.splitlines():
                linha = linha.strip()
                if linha:
                    numeros.append(linha)

        if not numeros:
            return None

        normalizados = {TargetedScanner.normalizar_numero(n) for n in numeros}
        normalizados.discard("")

        self.lbl_alvo_status.config(
            text=f"✔  {len(normalizados):,} números únicos prontos para varredura.",
            foreground="green")

        if not silencioso:
            messagebox.showinfo("Números carregados",
                f"{len(normalizados):,} números únicos carregados para varredura.")
        return normalizados

    def _iniciar_scan_direcionado(self):
        raiz = self.ent_raiz_scan.get().strip()
        if not os.path.isdir(raiz):
            messagebox.showerror("Erro", "Pasta raiz para varredura inválida.")
            return
        destino = self.ent_dest_scan.get().strip()
        if not destino:
            messagebox.showerror("Erro", "Informe a pasta de destino.")
            return

        numeros_alvo = self._carregar_numeros_alvo()
        if not numeros_alvo:
            messagebox.showerror("Erro",
                "Nenhum número carregado.\n\nInforme os números pela planilha ou pela caixa de texto.")
            return

        db = self._get_db()
        if db is None:
            return

        os.makedirs(destino, exist_ok=True)
        self.db = db
        self._scanner_direto = TargetedScanner(db)
        self._destino_scan   = destino
        self._numeros_alvo   = numeros_alvo
        self._resultados_scan: list[ResultadoBusca] = []

        self._parar.clear()
        self._stats_idx  = EstatisticasIndexacao()
        self._ts_inicio  = time.monotonic()
        self._modo_ativo = "scan_direcionado"

        self.lista.delete(0, tk.END)
        self.lista.insert(tk.END,
            "🎯  VARREDURA DIRECIONADA INICIADA",
            f"    Números-alvo  : {len(numeros_alvo):,}",
            f"    Raiz          : {raiz}",
            f"    Destino       : {destino}",
            "─" * 80,
        )
        self._set_ui_ativa(modo="scan_direcionado")
        threading.Thread(target=self._worker_scan_direcionado, args=(raiz,),
                         daemon=True, name="ScanDirecionado").start()
        self._agendar_ui()

    def _worker_scan_direcionado(self, raiz: str):
        try:
            self._scanner_direto.varrer_e_salvar(
                raiz=raiz,
                numeros_alvo=self._numeros_alvo,
                stats=self._stats_idx,
                parar=self._parar,
                callback_resultado=self._on_arquivo_encontrado_thread,
            )
        except Exception as e:
            log.exception("Erro crítico no scan: %s", e)
            self._stats_idx.fase = f"ERRO: {e}"
        finally:
            self.root.after(0, self._finalizar_scan_direcionado)

    def _on_arquivo_encontrado_thread(self, info: ArquivoInfo):
        resultado = ResultadoBusca(telefone=info.telefone, nome=info.nome, caminho=info.caminho)
        destino_arquivo = os.path.join(self._destino_scan, info.nome)
        try:
            os.makedirs(self._destino_scan, exist_ok=True)
            if not os.path.exists(destino_arquivo):
                shutil.copy2(info.caminho, destino_arquivo)
            resultado.copiado = True
        except Exception as e:
            resultado.erro = str(e)
            log.warning("Falha ao copiar %s: %s", info.nome, e)
            self.root.after(0, lambda l=f"  ✘  ERRO: {info.nome} — {e}": self._append_lista(l))

        self._resultados_scan.append(resultado)
        icone = "✔" if resultado.copiado else "✘"
        linha = f"  {icone}  [{info.telefone}]  {info.nome}"
        self.root.after(0, lambda l=linha: self._append_lista(l))

    def _append_lista(self, linha: str):
        if self.lista.size() < MAX_LINHAS_UI:
            self.lista.insert(tk.END, linha)
            self.lista.yview_moveto(1.0)

    def _finalizar_scan_direcionado(self):
        self._cancelar_timer_ui()
        self._set_ui_inativa()
        s        = self._stats_idx
        elapsed  = max(time.monotonic() - self._ts_inicio, 0.01)
        copiados = sum(1 for r in self._resultados_scan if r.copiado)
        erros    = sum(1 for r in self._resultados_scan if r.erro)
        vel      = int(s.total_arquivos / elapsed)

        self.lbl_fase.config(text=f"Varredura concluída em {elapsed:.1f}s.", foreground="green")
        self.lbl_contadores.config(
            text=(f"Varridos: {s.total_arquivos:,}   Encontrados: {s.novos:,}   "
                  f"Copiados: {copiados:,}   Erros: {erros:,}   Vel: {vel:,}/s"))
        self.lista.insert(tk.END, "─"*80, "  CONCLUÍDO",
            f"  Varridos: {s.total_arquivos:,}   Encontrados: {s.novos:,}",
            f"  Copiados: {copiados:,}   Erros: {erros:,}   Vel: {vel:,}/s",
            f"  Tempo: {elapsed:.1f}s")
        self._verificar_banco()

        msg = (f"Varredura concluída!\n\nVarridos: {s.total_arquivos:,}\n"
               f"Encontrados: {s.novos:,}\nCopiados: {copiados:,}\nErros: {erros:,}\n"
               f"Velocidade: {vel:,} arq/s\nTempo: {elapsed:.1f}s")
        if erros:
            msg += f"\n\n⚠ {erros} erro(s) de cópia — veja a lista."
        messagebox.showinfo("Varredura direcionada", msg)

        if copiados > 0 and os.path.isdir(self._destino_scan):
            try:
                subprocess.Popen(["explorer", os.path.normpath(self._destino_scan)])
            except Exception:
                pass

    # ─────────────────────────────────────────────────────────────────────────
    # TIMER UI
    # ─────────────────────────────────────────────────────────────────────────

    def _agendar_ui(self):
        self._after_id = self.root.after(UI_INTERVALO_MS, self._atualizar_ui)

    def _atualizar_ui(self):
        elapsed = max(time.monotonic() - self._ts_inicio, 0.01)
        modo    = self._modo_ativo

        if modo == "indexando":
            s   = self._stats_idx
            vel = int(s.total_arquivos / elapsed)
            self.lbl_fase.config(text=f"Indexando: {s.fase}", foreground="blue")
            if s.pasta_atual:
                p = s.pasta_atual
                self.lbl_pasta.config(text=("…" + p[-90:]) if len(p) > 93 else p)
            total_dirs  = s.dirs_varridos + s.dirs_pulados
            pct_pulados = (s.dirs_pulados / total_dirs * 100) if total_dirs > 0 else 0
            self.lbl_contadores.config(text=(
                f"Dirs pulados: {s.dirs_pulados:,} ({pct_pulados:.0f}%)   "
                f"Dirs varridos: {s.dirs_varridos:,}   "
                f"Arq: {s.total_arquivos:,}   Novos: {s.novos:,}   "
                f"Vel: {vel:,}/s   Tempo: {elapsed:.0f}s"))

        elif modo == "buscando":
            s = self._stats_bus
            self.lbl_fase.config(text=f"Busca: {s.fase}", foreground="blue")
            self.lbl_contadores.config(text=(
                f"Buscados: {s.total_numeros:,}   Encontrados: {s.encontrados:,}   "
                f"Copiados: {s.copiados:,}   Tempo: {elapsed:.1f}s"))

        elif modo == "limpando":
            s = self._stats_limp
            self.lbl_fase.config(text=f"Limpeza: {s.fase}", foreground="darkorange")
            self.lbl_contadores.config(text=(
                f"Verificados: {s.total_verificados:,}   Removidos: {s.removidos:,}   Tempo: {elapsed:.0f}s"))

        elif modo == "scan_direcionado":
            s   = self._stats_idx
            vel = int(s.total_arquivos / elapsed)
            self.lbl_fase.config(text=f"Varrendo: {s.fase}", foreground="darkgreen")
            if s.pasta_atual:
                p = s.pasta_atual
                self.lbl_pasta.config(text=("…" + p[-90:]) if len(p) > 93 else p)
            self.lbl_contadores.config(text=(
                f"Varridos: {s.total_arquivos:,}   Encontrados: {s.novos:,}   "
                f"Vel: {vel:,}/s   Tempo: {elapsed:.0f}s"))

        self._agendar_ui()

    def _cancelar_timer_ui(self):
        if self._after_id:
            self.root.after_cancel(self._after_id)
            self._after_id = None

    # ─────────────────────────────────────────────────────────────────────────
    # ESTADO DA UI
    # ─────────────────────────────────────────────────────────────────────────

    def _parar_operacao(self):
        self._parar.set()
        self.lbl_fase.config(text="Parando…", foreground="orange")
        self.btn_parar_idx.config(state="disabled")
        self.btn_parar_bus.config(state="disabled")
        self.btn_parar_scan.config(state="disabled")

    def _set_ui_ativa(self, modo: str):
        for btn in (self.btn_indexar, self.btn_avaliar, self.btn_limpar,
                    self.btn_buscar, self.btn_scan_direto):
            btn.config(state="disabled")
        self.btn_parar_idx.config(state="disabled")
        self.btn_parar_bus.config(state="disabled")
        self.btn_parar_scan.config(state="disabled")
        if modo in ("indexando", "limpando"):
            self.btn_parar_idx.config(state="normal")
        elif modo == "buscando":
            self.btn_parar_bus.config(state="normal")
        elif modo == "scan_direcionado":
            self.btn_parar_scan.config(state="normal")
        self.progressbar.start(12)

    def _set_ui_inativa(self):
        for btn in (self.btn_indexar, self.btn_avaliar, self.btn_limpar,
                    self.btn_buscar, self.btn_scan_direto):
            btn.config(state="normal")
        self.btn_parar_idx.config(state="disabled")
        self.btn_parar_bus.config(state="disabled")
        self.btn_parar_scan.config(state="disabled")
        self.progressbar.stop()


# ─────────────────────────────────────────────────────────────────────────────
# PONTO DE ENTRADA
# ─────────────────────────────────────────────────────────────────────────────

if __name__ == "__main__":
    root = tk.Tk()
    root.minsize(900, 600)
    w, h = 1020, 720
    sx = (root.winfo_screenwidth()  - w) // 2
    sy = (root.winfo_screenheight() - h) // 2
    root.geometry(f"{w}x{h}+{sx}+{sy}")
    app = AudioSearcherApp(root)
    root.mainloop()
